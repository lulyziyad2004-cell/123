{
  "entities": {
    "Lawyer": {
      "title": "Lawyer",
      "description": "Represents a lawyer/advisor in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone"]
    },
    "Tenant": {
      "title": "Tenant",
      "description": "Represents a tenant/client in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "propertyNo": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone"]
    },
    "Session": {
      "title": "Session",
      "description": "Represents a court/legal session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "caseId": { "type": "string" },
        "caseTitle": { "type": "string" },
        "date": { "type": "string" },
        "day": { "type": "string" },
        "time": { "type": "string" },
        "plaintiff": { "type": "string" },
        "defendant": { "type": "string" },
        "lawyerId": { "type": "string" },
        "tenantId": { "type": "string" },
        "courtRoom": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "city": { "type": "string" },
        "circuitNo": { "type": "string" },
        "hijriDate": { "type": "string" },
        "agencyNo": { "type": "string" },
        "agencyExpiryDate": { "type": "string" }
      },
      "required": ["id", "caseId", "caseTitle", "date", "time", "plaintiff", "defendant", "lawyerId", "tenantId", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Represents a financial invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "amount": { "type": "number" },
        "issueDate": { "type": "string" },
        "dueDate": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "tenantId", "tenantName", "amount", "issueDate", "dueDate", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Represents an in-app or push notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetRole": { "type": "string" },
        "targetId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "isRead": { "type": "boolean" },
        "type": { "type": "string" },
        "sender": { "type": "string" }
      },
      "required": ["id", "targetRole", "targetId", "title", "message", "timestamp", "isRead", "type"]
    }
  },
  "firestore": {
    "/lawyers/{lawyerId}": {
      "schema": "Lawyer",
      "description": "Collection of lawyers"
    },
    "/tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Collection of clients/tenants"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Collection of legal court sessions"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of billing invoices"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user and system notifications"
    }
  }
}
